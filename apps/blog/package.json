{
  "name": "@app/blog",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "type-check": "tsc --noEmit",
    "generate:search": "tsx scripts/generate-search-index.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "generate:rss": "tsx scripts/generate-rss.ts",
    "check:content": "tsx scripts/check-content.ts",
    "format": "prettier --write .",
    "generate:knowledge": "tsx scripts/generate-knowledge-index.ts",
    "prebuild": "CONTENT_DIR=../../content DATA_DIR=../../data bash -c 'npm run generate:knowledge && npm run generate:search && npm run generate:sitemap && npm run generate:rss'",
    "test": "CONTENT_DIR=../../content DATA_DIR=../../data vitest run",
    "migrate:db": "tsx scripts/migrate-json-to-sqlite.ts",
    "backup:db": "tsx scripts/backup-db.ts",
    "check:media": "tsx scripts/check-media.ts",
    "migrate:images": "tsx scripts/migrate-images-to-s3.ts"
  },
  "dependencies": {
    "@pkg/auth": "*",
    "@aws-sdk/client-s3": "^3.1066.0",
    "better-sqlite3": "^12.10.0",
    "clsx": "^2.1.1",
    "fuse.js": "^7.0.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "lucide-react": "0.474.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.13.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-rehype": "^11.1.2",
    "rss": "^1.2.2",
    "sharp": "^0.35.0",
    "shiki": "^1.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "@types/prettier": "^3.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/rss": "^0.0.32",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
