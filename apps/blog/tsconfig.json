{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next.build/types/**/*.ts",
    ".next.dev/types/**/*.ts",
    ".next.dev/dev/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next.build/dev/types/**/*.ts",
    ".next.verify/types/**/*.ts",
    ".next.verify/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
