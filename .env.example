NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=AI-Tech-Blog

# 管理后台密码（用于保护 /admin 页面和所有写接口）
ADMIN_PASSWORD=your-password

# 会话签名密钥（独立于密码，≥32 字符随机串；生成：openssl rand -hex 32）
# 不配置时回退到由 ADMIN_PASSWORD 派生（不安全，仅作兼容）
SESSION_SECRET=

# Giscus 评论（构建期内联，修改后需重新 build）。配置步骤见 docs/giscus-setup.md
NEXT_PUBLIC_GISCUS_REPO=your-name/your-blog
NEXT_PUBLIC_GISCUS_REPO_ID=your-repo-id
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=your-category-id

# AI 聊天机器人配置（用于站内知识助手，可选）
# 选择 AI 供应商：dashscope | anthropic | openai | custom
AI_PROVIDER=dashscope

# API 密钥（根据供应商填写）
# 千问 DashScope: https://bailian.console.aliyun.com/
# Anthropic Claude: https://console.anthropic.com/
AI_API_KEY=your-api-key

# API 地址（可自定义，支持任意 OpenAI 兼容接口）
# 千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# Anthropic: https://api.anthropic.com/v1
# 自定义/本地模型: 填对应 API 基础地址
AI_API_BASE_URL=

# 模型名称（留空则用代码内置默认：千问 qwen3.6-max / Anthropic claude-opus-4-8）
# 千问: qwen3.6-max / qwen-max / qwen-plus / qwen-turbo
# Anthropic: claude-opus-4-8 / claude-sonnet-4-6
AI_MODEL=qwen3.6-max

# 飞书开放平台应用凭证（用于从飞书导入文章）
# 在 https://open.feishu.cn/app 创建应用并获取
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
