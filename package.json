{
  "name": "micro-ai-blog-monorepo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @app/blog",
    "build": "npm run build -w @app/blog",
    "start": "npm run start -w @app/blog",
    "lint": "npm run lint -w @app/blog",
    "type-check": "npm run type-check -w @app/blog",
    "test": "npm run test -w @app/blog && npm run test -w @pkg/content",
    "format": "npm run format -w @app/blog",
    "backup:db": "npm run backup:db -w @app/blog",
    "check:content": "npm run check:content -w @app/blog"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.11.1",
    "js-yaml": "^5.0.0"
  }
}
